@model LibrarySystem.Web.ViewModels.Category.CategoryViewModel

@{
    ViewData["Title"] = "تعديل تصنيف";
}

<link rel="stylesheet" href="~/css/admin-form.css" />

<div class="admin-form-wrap">
    <div class="admin-form__crumb"><a asp-action="Index">التصنيفات</a> / تعديل</div>
    <h2 class="admin-form__title">تعديل تصنيف</h2>

    <div asp-validation-summary="All" class="text-danger"></div>

    <form asp-action="Edit" method="post" class="admin-form">
        <input type="hidden" asp-for="Id" />

        <div class="admin-field">
            <label asp-for="Name"></label>
            <input asp-for="Name" />
            <span asp-validation-for="Name"></span>
        </div>

        <div class="admin-field">
            <label asp-for="Description"></label>
            <textarea asp-for="Description" rows="3"></textarea>
        </div>

        <div class="admin-form__actions">
            <button type="submit" class="btn-library-primary" style="border:none;">حفظ التعديلات</button>
            <a asp-action="Index" class="btn-library-ghost">إلغاء</a>
        </div>
    </form>
</div>