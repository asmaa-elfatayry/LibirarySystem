@model List<Domain.Entities.Category>

@{
    ViewData["Title"] = "التصنيفات";
}

<h2>التصنيفات</h2>

<a asp-action="Create" class="btn btn-success mb-3">+ إضافة تصنيف</a>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>الاسم</th>
            <th>الوصف</th>
            <th>إجراءات</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var category in Model)
        {
            <tr>
                <td>@category.Name</td>
                <td>@category.Description</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@category.Id" class="btn btn-sm btn-primary">تعديل</a>
                    <a asp-action="Delete" asp-route-id="@category.Id" class="btn btn-sm btn-danger">حذف</a>
                </td>
            </tr>
        }
    </tbody>
</table>