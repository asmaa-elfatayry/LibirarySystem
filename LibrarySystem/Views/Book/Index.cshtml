@model List<LibrarySystem.Web.ViewModels.Book.BookViewModel>

@{
    ViewData["Title"] = "الكتب";
}

<link rel="stylesheet" href="~/css/category-cards.css" />
<link rel="stylesheet" href="~/css/book-cards.css" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
@Html.AntiForgeryToken()

<div class="cat-header">
    <h2 class="cat-header__title">الكتب</h2>
    <span class="cat-header__count">@Model.Count كتاب مسجّل</span>
    @if (User.IsInRole("Admin") || User.IsInRole("Librarian"))
    {
        <a asp-action="Create" class="btn-library-primary">+ إضافة كتاب</a>
    }
</div>

<div class="cat-grid">
    @foreach (var book in Model)
    {
        <div class="cat-card book-card" id="cat-card-@book.Id" onclick="goToBookDetails(event, '@book.Id')" style="cursor:pointer;">
            <div class="book-card__cover">
                @if (!string.IsNullOrEmpty(book.CoverImageUrl))
                {
                    <img src="@book.CoverImageUrl" alt="@book.Title" />
                }
                else
                {
                    <div class="book-card__cover--empty">لا يوجد غلاف</div>
                }
                @if (!string.IsNullOrEmpty(book.CategoryName))
                {
                    <span class="book-card__category">@book.CategoryName</span>
                }
            </div>

            <div class="book-card__body">
                <div class="cat-card__title">@book.Title</div>
                <div class="book-card__author">@book.AuthorName</div>

                <div class="book-card__footer">
                    <span class="book-card__publisher">@book.PublisherName</span>
                    <span class="book-card__isbn">@book.ISBN</span>
                </div>
                @if (User.IsInRole("Admin") || User.IsInRole("Librarian"))
                {
                   
              
                <div class="cat-card__actions">
                    <a asp-action="Edit" asp-route-id="@book.Id" class="cat-action cat-action--edit">تعديل</a>
                    <button type="button" class="cat-action cat-action--delete"
                            onclick="confirmDelete('@book.Id', '@book.Title')">
                        حذف
                    </button>
                </div>
                  }
            </div>
        </div>
    }
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/modules/book/index.js"></script>
}