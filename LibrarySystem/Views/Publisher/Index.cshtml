@model List<LibrarySystem.web.ViewModels.Publisher.PublisherViewModel>

@{
    ViewData["Title"] = "الناشرين";
}

<link rel="stylesheet" href="~/css/category-cards.css" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
@Html.AntiForgeryToken()

<div class="cat-header">
    <h2 class="cat-header__title">الناشرين</h2>
    <span class="cat-header__count">@Model.Count ناشر مسجّل</span>
    <a asp-action="Create" class="btn-library-primary">+ إضافة ناشر</a>
</div>

@if (!Model.Any())
{
    <p class="cat-empty">لسه مفيش ناشرين مضافين.</p>
}
else
{
    <div class="cat-grid">
        @foreach (var publisher in Model)
        {
            <div class="cat-card" id="cat-card-@publisher.Id">
                <span class="cat-card__tab">Publisher</span>
                <div class="cat-card__title">@publisher.Name</div>
                <div class="cat-card__desc">
                    @(string.IsNullOrWhiteSpace(publisher.Address) ? "بدون عنوان" : publisher.Address)
                </div>
                <div class="cat-card__actions">
                    <a asp-action="Edit" asp-route-id="@publisher.Id" class="cat-action cat-action--edit">تعديل</a>
                    <button type="button" class="cat-action cat-action--delete"
                            onclick="confirmDelete('@publisher.Id', '@publisher.Name')">
                        حذف
                    </button>
                </div>
            </div>
        }
    </div>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/modules/publisher/index.js"></script>
}