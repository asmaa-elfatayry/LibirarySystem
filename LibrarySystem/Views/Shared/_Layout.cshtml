<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LibrarySystem</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site-extended.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site-animations.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/LibrarySystem.styles.css" asp-append-version="true" />
</head>
<body>
    <header class="site-header">
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm mb-3">
            <div class="container-fluid">
                <a class="navbar-brand site-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <span class="site-brand__mark">📖</span> LibrarySystem
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav site-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">الرئيسية</a>
                        </li>
                        @if (User.IsInRole("Admin") || User.IsInRole("Librarian"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Dashboard" asp-action="Index">لوحة التحكم</a>
                            </li>
                        }
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="User" asp-action="Index">إدارة المستخدمين</a>
                            </li>
                        }
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Book" asp-action="Index">الكتب</a>
                        </li>
                        @if (User.IsInRole("Admin") || User.IsInRole("Librarian"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Category" asp-action="Index">التصنيفات</a>
                            </li>
                        }
                        @if (User.IsInRole("Admin") || User.IsInRole("Librarian"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Author" asp-action="Index">المؤلفين</a>
                            </li>
                        }
                        @if (User.IsInRole("Admin") || User.IsInRole("Librarian"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Publisher" asp-action="Index">الناشرين</a>
                            </li>
                        }
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Loan" asp-action="Index">الاستعارات</a>
                            </li>
                        }
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Reservation" asp-action="MyReservations">حجوزاتي</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Fine" asp-action="MyFines">غراماتي</a>
                        </li>
                        @if (User.IsInRole("Admin") || User.IsInRole("Librarian"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Report" asp-action="Index">التقارير</a>
                            </li>
                        }
                    </ul>

                    <ul class="navbar-nav ms-auto align-items-sm-center">
                        <li class="nav-item mx-2">
                            <button id="themeToggle" class="theme-toggle" type="button">
                                <span id="themeIcon">🌙</span>
                                <span id="themeLabel">دارك مود</span>
                            </button>
                        </li>
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item ms-sm-3">
                                @{
                                    var fullName = User.FindFirst("FullName")?.Value ?? "زائر";
                                }
                                <span class="site-user">@fullName</span>
                            </li>
                            <li class="nav-item">
                                <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline logout-form">
                                    <button type="submit" class="logout-icon-btn" title="تسجيل خروج">
                                        <svg class="logout-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" /><polyline points="16 17 21 12 16 7" /><line x1="21" y1="12" x2="9" y2="12" /></svg>
                                    </button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item ms-sm-3 auth-links">
                                <a class="nav-link auth-link" asp-controller="Account" asp-action="Login" title="تسجيل دخول">
                                    <svg class="auth-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4" /><polyline points="10 17 15 12 10 7" /></svg>
                                    <span class="auth-label">دخول</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link auth-link" asp-controller="Account" asp-action="Register" title="إنشاء حساب">
                                    <svg class="auth-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-3-3.87" /><path d="M4 21v-2a4 4 0 0 1 3-3.87" /><circle cx="12" cy="7" r="4" /></svg>
                                    <span class="auth-label">حساب</span>
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="site-footer">
        <div class="tex-center">
            <div class="footer-content">
                <p class="footer-copyright">
                    &copy; 2026 <strong>LibrarySystem</strong> - جميع الحقوق محفوظة.
                </p>
                <p class="footer-quote">
                    "Read. Learn. Grow."
                </p>
            </div>
        </div>
    </footer>



    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/theme.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {

        @if (TempData["Success"] != null)
        {
            <text>
                Swal.fire({
                icon: 'success',
                title: 'Success',
                text: '@TempData["Success"]',
                confirmButtonText: 'OK',
                confirmButtonColor: '#198754',
                timer: 2500,
                timerProgressBar: true
                });
            </text>
        }

        @if (TempData["Error"] != null)
        {
            <text>
                Swal.fire({
                icon: 'error',
                title: 'Oops!',
                text: '@TempData["Error"]',
                confirmButtonText: 'Close',
                confirmButtonColor: '#dc3545'
                });
            </text>
        }

        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>