@model LibrarySystem.ViewModels.RegisterViewModel

@{
    Layout = null;
    ViewData["Title"] = "إنشاء حساب";
}
<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
<link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
<link rel="stylesheet" href="~/LibrarySystem.styles.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/auth.css" />

<div class="auth-page">
    <div class="library-card">
        <div class="library-stamp">New Member</div>

        <div class="library-card__eyebrow">Library Card No. — Registration</div>
        <h2 class="library-card__title">إنشاء حساب جديد</h2>
        <p class="library-card__subtitle">اعمل بطاقتك، وابدأ تستعير.</p>

     

        <form asp-action="Register" method="post">
            <div class="library-field">
                <label asp-for="FullName"></label>
                <input asp-for="FullName" />
                <span asp-validation-for="FullName" class="text-danger"></span>
            </div>

            <div class="library-field">
                <label asp-for="Email"></label>
                <input asp-for="Email" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="library-field">
                <label asp-for="Password"></label>
                <input asp-for="Password" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="library-field">
                <label asp-for="ConfirmPassword"></label>
                <input asp-for="ConfirmPassword" />
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>

            <button type="submit" class="library-submit">تسجيل</button>
        </form>

        <p class="library-card__footer">
            عندك حساب بالفعل؟ <a asp-controller="Account" asp-action="Login">سجّل دخول</a>
        </p>
    </div>
</div>

@section Scripts {
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/theme.js"></script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}