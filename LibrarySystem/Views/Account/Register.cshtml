@model LibrarySystem.web.ViewModels.Account.RegisterViewModel

@{
    Layout = null;
    ViewData["Title"] = "إنشاء حساب";
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - مكتبة</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site-animations.css" asp-append-version="true" />
</head>
<body>
    <div class="auth-page">
        <div class="auth-wrapper">
            <div class="auth-card">
                <!-- Header -->
                <div class="auth-header">
                    <span class="auth-header__icon">📖</span>
                    <h1 class="auth-header__title">مرحباً بك</h1>
                    <p class="auth-header__subtitle">أدخل بياناتك لإنشاء حساب جديد</p>
                </div>

                <!-- Form -->
                <form asp-action="Register" method="post">
                    <div asp-validation-summary="ModelOnly" class="auth-validation"></div>

                    <div class="auth-field">
                        <label asp-for="FullName">الاسم الكامل</label>
                        <input asp-for="FullName" placeholder="أدخل اسمك الثلاثي" />
                        <span asp-validation-for="FullName" class="text-danger"></span>
                    </div>

                    <div class="auth-field">
                        <label asp-for="Email">البريد الإلكتروني</label>
                        <input asp-for="Email" type="email" placeholder="name@example.com" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="auth-field">
                        <label asp-for="Password">كلمة المرور</label>
                        <input asp-for="Password" type="password" placeholder="أدخل كلمة مرور قوية" />
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <div class="auth-field">
                        <label asp-for="ConfirmPassword">تأكيد كلمة المرور</label>
                        <input asp-for="ConfirmPassword" type="password" placeholder="أعد كتابة كلمة المرور" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                    </div>

                    <button type="submit" class="auth-btn">إنشاء الحساب</button>
                </form>

                <!-- Footer -->
                <div class="auth-footer">
                    لديك حساب؟ <a asp-controller="Account" asp-action="Login">سجل الدخول</a>
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/theme.js"></script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
</body>
</html>