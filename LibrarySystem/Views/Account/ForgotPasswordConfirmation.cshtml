@{
    ViewData["Title"] = "تحقق من بريدك";
    Layout = null;
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - LibrarySystem</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site-extended.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site-animations.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/LibrarySystem.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/error-pages.css" />
</head>

<body>

    <div class="error-page">

        <div class="error-page__code">✉</div>

        <h1 class="error-page__title">
            تحقق من بريدك الإلكتروني
        </h1>

        <p class="error-page__desc">
            إذا كان البريد الإلكتروني مسجلًا لدينا، فستصلك رسالة تحتوي على رابط إعادة تعيين كلمة المرور.
            يُرجى التحقق من صندوق الوارد أو مجلد الرسائل غير المرغوب فيها.
        </p>

        <a asp-action="Login" class="btn-library-primary">
            العودة إلى تسجيل الدخول
        </a>

    </div>

</body>
</html>