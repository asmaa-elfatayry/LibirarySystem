@using LibrarySystem.web.ViewModels.Account
@model ForgotPasswordViewModel

@{
    Layout = null;
    ViewData["Title"] = "نسيت كلمة المرور";
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - LibrarySystem</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site-extended.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site-animations.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/LibrarySystem.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/auth.css" />
</head>

<body>

    <div class="auth-page">
        <div class="auth-wrapper">
            <div class="auth-card">

                <div class="auth-header">
                    <span class="auth-header__icon">🔑</span>
                    <h2 class="auth-header__title">نسيت كلمة المرور؟</h2>
                    <p class="auth-header__subtitle">
                        أدخل بريدك الإلكتروني وسنرسل لك رابط إعادة التعيين.
                    </p>
                </div>

                <div asp-validation-summary="All" class="auth-validation"></div>

                <form asp-action="ForgotPassword" method="post">

                    <div class="auth-field">
                        <label asp-for="Email"></label>
                        <input asp-for="Email" placeholder="example@email.com" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <button type="submit" class="auth-btn">
                        إرسال رابط إعادة التعيين
                    </button>

                </form>

                <p class="auth-footer">
                    <a asp-action="Login">العودة إلى تسجيل الدخول</a>
                </p>

            </div>
        </div>
    </div>


    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/theme.js"></script>

    <partial name="_ValidationScriptsPartial" />

</body>
</html>