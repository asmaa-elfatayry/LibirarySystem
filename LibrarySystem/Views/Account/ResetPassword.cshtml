@using LibrarySystem.web.ViewModels.Account
@model ResetPasswordViewModel

@{
    ViewData["Title"] = "إعادة تعيين كلمة المرور";
    Layout = null;
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - LibrarySystem</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site-extended.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site-animations.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/LibrarySystem.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/auth.css" />
</head>

<body>

    <div class="auth-page">

        <div class="auth-wrapper">

            <div class="auth-card">

                <div class="auth-header">
                    <span class="auth-header__icon">🔒</span>

                    <h2 class="auth-header__title">
                        إعادة تعيين كلمة المرور
                    </h2>

                    <p class="auth-header__subtitle">
                        قم بإنشاء كلمة مرور جديدة لحسابك.
                    </p>
                </div>

                <div asp-validation-summary="All" class="auth-validation"></div>

                <form asp-action="ResetPassword" method="post">

                    <input type="hidden" asp-for="UserId" />
                    <input type="hidden" asp-for="Token" />

                    <div class="auth-field">
                        <label asp-for="NewPassword"></label>
                        <input asp-for="NewPassword" placeholder="••••••••" />
                        <span asp-validation-for="NewPassword" class="text-danger"></span>
                    </div>

                    <div class="auth-field">
                        <label asp-for="ConfirmPassword"></label>
                        <input asp-for="ConfirmPassword" placeholder="••••••••" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                    </div>

                    <button type="submit" class="auth-btn">
                        تحديث كلمة المرور
                    </button>

                </form>

                <p class="auth-footer">
                    <a asp-controller="Account" asp-action="Login">
                        العودة إلى تسجيل الدخول
                    </a>
                </p>

            </div>

        </div>

    </div>


    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/theme.js"></script>

    <partial name="_ValidationScriptsPartial" />

</body>
</html>