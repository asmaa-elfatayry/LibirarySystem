@model LibrarySystem.web.ViewModels.Account.LoginViewModel

@{
    ViewData["Title"] = "تسجيل الدخول";
    Layout = null;
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - مكتبة</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site-animations.css" asp-append-version="true" />
</head>
<body>
    <div class="auth-page">
        <div class="auth-wrapper">
            <!-- Left Side Info -->
            <div class="auth-info">
                <h1 class="auth-info__title">مرحباً بك في مكتبتنا</h1>
                <p class="auth-info__text">اكتشف مكتبة رقمية شاملة تضم آلاف الكتب والمراجع العلمية. ادخل الآن وابدأ رحلتك مع المعرفة.</p>
                <ul class="auth-info__features">
                    <li class="auth-info__feature">مكتبة تضم آلاف الكتب المتنوعة</li>
                    <li class="auth-info__feature">بحث متقدم وتصنيفات منظمة</li>
                    <li class="auth-info__feature">حفظ المفضلة وإنشاء قوائم القراءة</li>
                    <li class="auth-info__feature">توصيات شخصية بناءً على اهتماماتك</li>
                </ul>
            </div>

            <!-- Right Side Login Form -->
            <div class="exlibris-frame">
                <div class="exlibris-card">
                    <div class="exlibris-mark">ك</div>

                    <div class="exlibris-card__eyebrow">عضو المكتبة</div>
                    <h2 class="exlibris-card__title">تسجيل الدخول</h2>
                    <p class="exlibris-card__subtitle">مرحباً بعودتك إلى مكتبتك.</p>

                    <form asp-action="Login" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="exlibris-field">
                            <label asp-for="Email"></label>
                            <input asp-for="Email" type="email" placeholder="أدخل بريدك الإلكتروني" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="exlibris-field">
                            <label asp-for="Password"></label>
                            <input asp-for="Password" type="password" placeholder="أدخل كلمة المرور" />
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>

                        <div class="exlibris-check">
                            <label asp-for="RememberMe">
                                <input asp-for="RememberMe" />
                                <span>تذكرني</span>
                            </label>
                        </div>

                        <button type="submit" class="exlibris-submit">دخول</button>
                    </form>

                    <p class="exlibris-card__footer">
                        ليس لديك حساب؟ <a asp-controller="Account" asp-action="Register">إنشاء حساب جديد</a>
                    </p>
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/theme.js"></script>

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
</body>
</html>
